+"use client";
+
+import { useEffect, useRef } from "react";
+import { Map, MapControls, type MapRef } from "@/registry/map";
+import { drawRoute } from "@/lib/osrm-route";
+
+const START: [number, number] = [-74.006, 40.7128];
+const END: [number, number] = [-73.935242, 40.73061];
+
+export default function MyMap() {
+  const mapRef = useRef<MapRef | null>(null);
+
+  useEffect(() => {
+    if (!mapRef.current) return;
+
+    drawRoute(mapRef.current, START, END).catch((error) => {
+      console.error("Route drawing failed:", error);
+    });
+  }, []);
+
+  return (
+    <div className="h-screen w-full">
+      <Map ref={mapRef} center={START} zoom={11}>
+        <MapControls />
+      </Map>
+    </div>
+  );
+}
